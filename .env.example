# Copa Phibra 2026 — variáveis de ambiente
# Copie este arquivo para `.env` e ajuste os valores.
# Em produção, rode o servidor com:  uvicorn app.main:app --env-file .env ...
# (o uvicorn carrega este arquivo para o ambiente antes de subir o app)

# OBRIGATÓRIA em produção (DEBUG=0). O app SE RECUSA a subir com o valor
# padrão de desenvolvimento quando DEBUG está desligado.
# Gere um valor forte com:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-um-valor-aleatorio-forte

# 0 = produção (padrão e recomendado). 1 = desenvolvimento (mostra stack traces,
# afrouxa o cookie de sessão e ignora a checagem do SECRET_KEY).
DEBUG=0

# Banco de dados. Padrão: SQLite local. Para PostgreSQL, ex.:
#   postgresql+psycopg://usuario:senha@host:5432/copa_phibra
DATABASE_URL=sqlite:///./copa_phibra.db

# Marque o cookie de sessão como Secure (só trafega via HTTPS).
# Deixe 0 se o acesso interno for por HTTP simples; ligue (1) atrás de HTTPS.
SESSION_HTTPS_ONLY=0
